\newcounter{numclause}[section]
\newcommand{\clause}[1]{%
    \stepcounter{numclause}%
    \vspace{0.5ex}\noindent
    \begin{tikzpicture}[baseline=(n.base)]
        \fill[ChartePrimaire](0,0)circle(0.22cm);
        \node[white,font=\tiny\bfseries](n)at(0,0){\thenumclause};
    \end{tikzpicture}
    \hspace{0.4em}\textbf{\color{CharteArdoise}#1}
    \par\vspace{0.3ex}}

