% ==============================================================================
% IV. TITRES
% ==============================================================================
\titleformat{\section}
    {\normalfont\large\bfseries\color{ChartePrimaire}}{}
    {0pt}
    {\colorbox{ChartePrimaire}{\color{white}\,\thesection\,}\hspace{0.6em}}
    [\vspace{-0.5ex}{\color{CharteVif}\titlerule[1.5pt]}\vspace{0.5ex}]
\titlespacing*{\section}{0pt}{1.8ex plus .5ex}{0.8ex plus .3ex}

\titleformat{\subsection}
    {\normalfont\normalsize\bfseries\color{CharteSecondaire}}
    {\color{CharteVif}\rule[-2pt]{3pt}{11pt}\hspace{0.5em}\thesubsection}
    {0.5em}{}
\titlespacing*{\subsection}{0pt}{1.2ex plus .4ex}{0.4ex plus .2ex}

\titleformat{\subsubsection}
    {\normalfont\small\bfseries\color{CharteGrisBleu}}
    {\thesubsubsection}{0.5em}{}
\titlespacing*{\subsubsection}{0pt}{0.8ex}{0.2ex}

